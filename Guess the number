#include <iostream>
#include <cstdlib>
using namespace std;

int main() {

	srand(time(0)); //This makes the number random each time you run the code
	double randomNum = rand() % 101;

	double userinput = 0;
	double guessiz = 0 + 1;
	
	while (userinput != randomNum) {
		cout << " Guess a number between 1-100! ";
		cin >> userinput;

		if (userinput == randomNum) {
			cout << "You're correct, good job! " << endl;
			cout << "You took " << guessiz << " guesses" << endl;
//If you're wrong, then it will say the sentence on the bottom, but if you are correct, then it will say the sentence at the top
		} else if (userinput < randomNum) {
			cout << "Good guess, but your number is too low \n";
		} else {
			cout << "Good guess, but your number is too high \n";
		}
	
	    guessiz++;
	}
	return 0;
}


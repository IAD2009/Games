#include <iostream>
#include <cstdlib>
#include <limits>
using namespace std;

int main() {

	srand(time(0)); //This makes the number random each time you run the code
	double randomNum = rand() % 101;

	double userinput = 0;
	double guessiz = 0 + 1;
	//The loop allows you to continue the game, despite getting the number wrong
	while (userinput != randomNum) {
		cout << "\nGuess a number between 0-100! ";
		cin >> userinput;
		cin.ignore(10000, '\n');
		//prevents code from crashing if letter is typed in 
			if (cin.fail()) {
	    cin.clear();
	    cin.ignore(10000, '\n');
	    cout << "\nInvalid input, please enter a number." << endl;
	    continue;
	}
	
	//Check if the range is correct
	    if (userinput < 1 || userinput > 100) {
	        cout << "It's supposed to be between 1-100 ";
	        continue;
	    }

		if (userinput == randomNum) {
			cout << "\nYou're correct, good job! " << endl;
			cout << "\nYou took " << guessiz << " guesses" << endl;
//If you're wrong, then it will say the sentence on the bottom, but if you are correct, then it will say the sentence at the top
		} else if (userinput < randomNum) {
			cout << "\nGood guess, but your number is too low ";
		} else {
			cout << "\nGood guess, but your number is too high ";
		}
	
	    guessiz++;
	}
	

	return 0;

}
